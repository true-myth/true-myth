{
  "typescript": {
    "lineWidth": 100,
    "semiColons": "always",
    "quoteStyle": "alwaysSingle",
    "trailingCommas": "onlyMultiLine",
  },
  "json": {},
  "excludes": ["**/node_modules", "**/*-lock.json"],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.88.2.wasm",
    "https://plugins.dprint.dev/json-0.18.0.wasm",
  ],
}
