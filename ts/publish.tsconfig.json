{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.tsconfig.json",
  "include": ["../src"],
  "compilerOptions": {
    "removeComments": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "../dist",
    "rootDir": "../src",
    "types": ["node"],
    "paths": {
      "true-myth": ["../src/index.ts"],
      "true-myth/eslint-plugin": ["../src/eslint-plugin/index.ts"],
      "true-myth/*": ["../src/*.ts"]
    }
  }
}
